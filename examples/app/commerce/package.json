{
  "name": "commerce",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "webhubProjectionManifest": "./dist/webhub-projection.json",
  "scripts": {
    "build": "pnpm run build:deps && pnpm run build:client && pnpm run build:protocol && pnpm run build:server",
    "build:deps": "pnpm --filter @microsoft/webhub --filter @microsoft/webhub-framework --filter @microsoft/webhub-router run build",
    "build:protocol": "cargo run -p microsoft-webhub-cli -- build ./src --plugin=webhub --projection-manifest ./dist/webhub-projection.json --css module --out ./dist",
    "build:client": "node ../../build-client.mjs",
    "build:server": "cargo check -p marketplace-api",
    "start:client": "pnpm run build:deps && node ../../build-client.mjs --watch",
    "start:server": "cargo run -p marketplace-api -- --port 3004 --no-tls --css=module",
    "start": "cargo xtask dev commerce",
    "test": "playwright test",
    "test:update-snapshots": "playwright test --update-snapshots"
  },
  "imports": {
    "#atoms/*": "./src/atoms/*",
    "#molecules/*": "./src/molecules/*",
    "#organisms/*": "./src/organisms/*",
    "#pages/*": "./src/pages/*"
  },
  "devDependencies": {
    "@microsoft/webhub": "workspace:*",
    "@microsoft/webhub-framework": "workspace:*",
    "@microsoft/webhub-router": "workspace:*",
    "@playwright/test": "catalog:",
    "esbuild": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  }
}
