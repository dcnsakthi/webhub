{
  "name": "todo-webhub-example",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm run build:deps && pnpm run build:client && pnpm run build:protocol",
    "build:deps": "pnpm --filter @microsoft/webhub --filter @microsoft/webhub-framework run build",
    "build:protocol": "cargo run -p microsoft-webhub-cli -- build ./src --plugin=webhub --projection-manifest ./dist/webhub-projection.json --out ./dist",
    "build:client": "node ../../build-client.mjs",
    "start:client": "pnpm run build:deps && node ../../build-client.mjs --watch",
    "start:server": "cargo run -p microsoft-webhub-cli -- serve ./src --state ./data/state.json --plugin=webhub --projection-manifest ./dist/webhub-projection.json --servedir ./dist --port 3006 --watch",
    "start": "cargo xtask dev todo-webhub",
    "test": "playwright test",
    "test:update-snapshots": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@microsoft/webhub": "workspace:*",
    "@microsoft/webhub-framework": "workspace:*",
    "@playwright/test": "catalog:",
    "esbuild": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  }
}
