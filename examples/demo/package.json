{
  "name": "webhub-demo-shell",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm run build:deps && node ../build-client.mjs && node -e \"const fs=require('node:fs');fs.copyFileSync('src/index.css','dist/index.css');fs.copyFileSync('src/demo-shell/demo-shell.css','dist/demo-shell.css')\"",
    "build:deps": "pnpm --filter @microsoft/webhub --filter @microsoft/webhub-framework run build",
    "start:client": "pnpm run build:deps && node ../build-client.mjs --watch",
    "start:server": "cargo run -p microsoft-webhub-cli -- serve ./src --state ./data/state.json --plugin=webhub --projection-manifest ./dist/webhub-projection.json --servedir ./dist --port 3099 --watch"
  },
  "devDependencies": {
    "@microsoft/webhub": "workspace:*",
    "@microsoft/webhub-framework": "workspace:*",
    "esbuild": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  }
}
